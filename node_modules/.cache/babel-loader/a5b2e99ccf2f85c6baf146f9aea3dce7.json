r","data":"base64:"},{"version":3,"names":["Actividad","name","components","data","cuestionario","tema","titulo","introduccion","barajarPreguntas","preguntas","id","texto","imagen","require","barajarRespuestas","opciones","esCorrecta","mensaje_correcto","mensaje_incorrecto","mensaje_final_aprobado","mensaje_final_reprobado"],"sources":["src/views/Actividad.vue"],"sourcesContent":["<template lang=\"pug\">\n  .curso-main-container.pb-3\n    BannerInterno(icono=\"far fa-question-circle\" titulo=\"Actividad didáctica\")\n    .container.tarjeta.tarjeta--blanca.p-4.p-md-5\n  \n      #Actividad                \n        <Actividad :cuestionario=\"cuestionario\"/>\n  \n  </template>\n\n<script>\nimport Actividad from 'ecored-pkg-fliz/plugin/components/actividad/Actividad.vue'\nexport default {\n  name:\n    'DescubriendoLaGestiNDeRecepciNYDespachoSegNLasCaracterSticasDelProducto',\n  components: {\n    Actividad,\n  },\n  data: () => ({\n    cuestionario: {\n      tema:\n        'Gestión de recepción y despacho según las características del producto',\n      titulo: 'Cuestionario',\n      introduccion:\n        '<b> Objetivo:</b> Evaluar la comprensión de los conceptos fundamentales sobre la gestión de recepción y despacho según las características del producto.',\n      barajarPreguntas: true,\n      preguntas: [\n        {\n          id: 1,\n          texto:\n            'El concepto y la naturaleza de la carga implica conocer los bienes o mercancías que se transportan y las propiedades específicas de los productos, como su tamaño, peso, fragilidad o requerimientos especiales.',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la gestión de recepción y despacho según las características del producto.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 2,\n          texto:\n            'Es cierto que las frutas y verduras son consideradas carga no perecedera debido a su larga vida útil y su capacidad para mantenerse en buen estado sin necesidad de refrigeración.',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la gestión de recepción y despacho según las características del producto.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 3,\n          texto:\n            'Es cierto que la carga suelta, sin embalaje, se refiere a productos que requieren embalaje adicional para su transporte y manipulación debido a su naturaleza o tamaño.',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la gestión de recepción y despacho según las características del producto.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 4,\n          texto:\n            'Es cierto que la carga a granel se transporta siempre en unidades individuales y con embalaje adecuado para su seguridad.',\n          imagen: require('@/assets/actividad/imagen4.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la gestión de recepción y despacho según las características del producto.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 5,\n          texto:\n            'Es cierto que la carga especial incluye únicamente productos peligrosos y de alto valor económico, sin considerar otros factores como la necesidad de conservación o el tamaño de la carga.',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la gestión de recepción y despacho según las características del producto.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 6,\n          texto:\n            'Es cierto que las bandas transportadoras fijas al techo no requieren ninguna infraestructura elevada para permitir el desplazamiento adecuado de los productos.',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la gestión de recepción y despacho según las características del producto.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 7,\n          texto:\n            'Es cierto que las transpaletas manuales requieren un mayor esfuerzo físico por parte del operario en comparación con las motorizadas.',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la gestión de recepción y despacho según las características del producto.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 8,\n          texto:\n            'Es cierto que el recibo de mercancías es el último paso en la gestión de un almacén, ya que solo implica la verificación de los productos.',\n          imagen: require('@/assets/actividad/imagen4.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la gestión de recepción y despacho según las características del producto.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 9,\n          texto:\n            'Es cierto que uno de los principales objetivos del proceso de recibido de mercancías es identificar inconformidades de manera temprana para mejorar la eficiencia operativa.',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la gestión de recepción y despacho según las características del producto.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 10,\n          texto:\n            'Es cierto que en el área de despacho, se debe garantizar que los productos devueltos debido a no conformidades se almacenen en el mismo espacio destinado para el <i>picking</i> o alistamiento de productos.',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la gestión de recepción y despacho según las características del producto.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n      ],\n      mensaje_final_aprobado:\n        '¡Excelente trabajo! posee una buena comprensión sobre la gestión de recepción y despacho según las características del producto. ¡Felicitaciones! Ha captado con claridad la gestión de recepción y despacho según las características del producto. ¡Siga explorando este fascinante mundo!',\n      mensaje_final_reprobado:\n        'No ha superado la actividad. Le recomendamos volver a revisar el componente formativo e intentar nuevamente la actividad didáctica.',\n    },\n  }),\n}\n</script>\n"],"mappings":"AAWA,OAAAA,SAAA;AACA;EACAC,IAAA,EACA;EACAC,UAAA;IACAF;EACA;EACAG,IAAA,EAAAA,CAAA;IACAC,YAAA;MACAC,IAAA,EACA;MACAC,MAAA;MACAC,YAAA,EACA;MACAC,gBAAA;MACAC,SAAA,GACA;QACAC,EAAA;QACAC,KAAA,EACA;QACAC,MAAA,EAAAC,OAAA;QACAC,iBAAA;QACAC,QAAA,GACA;UACAL,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,GACA;UACAN,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,EACA;QACAC,gBAAA,EACA;QACAC,kBAAA,EACA;MACA,GACA;QACAR,EAAA;QACAC,KAAA,EACA;QACAC,MAAA,EAAAC,OAAA;QACAC,iBAAA;QACAC,QAAA,GACA;UACAL,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,GACA;UACAN,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,EACA;QACAC,gBAAA,EACA;QACAC,kBAAA,EACA;MACA,GACA;QACAR,EAAA;QACAC,KAAA,EACA;QACAC,MAAA,EAAAC,OAAA;QACAC,iBAAA;QACAC,QAAA,GACA;UACAL,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,GACA;UACAN,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,EACA;QACAC,gBAAA,EACA;QACAC,kBAAA,EACA;MACA,GACA;QACAR,EAAA;QACAC,KAAA,EACA;QACAC,MAAA,EAAAC,OAAA;QACAC,iBAAA;QACAC,QAAA,GACA;UACAL,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,GACA;UACAN,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,EACA;QACAC,gBAAA,EACA;QACAC,kBAAA,EACA;MACA,GACA;QACAR,EAAA;QACAC,KAAA,EACA;QACAC,MAAA,EAAAC,O